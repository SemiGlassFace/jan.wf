---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.jpg';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Jan Piotrowski">
    <main class="home">
        <Navbar />

        <section id="home" class="hero">
            <div class="hero-image-wrap">
                <Image
                    src={profileImage}
                    alt="Picture of Jan Piotrowski"
                    class="hero-image"
                />
            </div>
            <div class="hero-content">
                <h1>Hi, I’m Jan Piotrowski</h1>
                <p>
                    I’m a Master Computer Science Student at TU Delft.
                </p>
                <p>
                    I currently work as a Machine Learning Engineer in Huawei's Amsterdam Research Centre.
                </p>
                <p>
                    You can read more about myself in <a href="/about">here</a>.
                </p>


                <div class="contact-area">
                    <p>Get in touch:</p>
                    <div class="contact-methods">
                        <div class="email-info">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mail-icon"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                            <span>me (at) jan.wf</span>
                        </div>

                        <div class="social-links" aria-label="Social media links">
                            <a
                                href="https://github.com/semiglassface"
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="GitHub profile"
                                title="GitHub"
                            >
                                <Image
                                    src="https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg/github.svg"
                                    alt=""
                                    class="social-icon"
                                    width={32}
                                    height={32}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </a>

                            <a
                                href="https://linkedin.com/in/jppiotrowski"
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="LinkedIn profile"
                                title="LinkedIn"
                            >
                                <Image
                                    src="https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg/linkedin.svg"
                                    alt=""
                                    class="social-icon"
                                    width={32}
                                    height={32}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </a>

                            <a
                                href="https://bsky.app/profile/jan.wf"
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="Bluesky profile"
                                title="Bluesky"
                            >
                                <Image
                                    src="https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg/bluesky.svg"
                                    alt=""
                                    class="social-icon"
                                    width={32}
                                    height={32}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    :global(body) {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
        background: #f8f9fb;
        color: #111827;
    }
    .home {
        display: flex;
        flex-direction: column;
    }

    .hero {
        max-width: 1100px;
        margin: 0 auto;
        padding: 4rem 2rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
        flex: 1;
    }

    .hero-image-wrap {
        display: flex;
        justify-content: center;
    }

    .hero-image {
        width: auto;
        max-width: 100%;
        max-height: 500px;
        height: auto;
        object-fit: cover;
        border-radius: 1.5rem;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
        background: #e5e7eb;
    }

    .hero-content h1 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin: 0 0 1rem;
        line-height: 1.15;
    }

    .hero-content p {
        font-size: 1.05rem;
        line-height: 1.5;
        color: #4b5563;
        max-width: 52ch;
        margin: 0;
        text-align: justify;
    }

    .contact-area {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
    }

    .contact-area p {
        font-weight: 600;
        margin-bottom: 1rem;
        color: #111827;
        text-align: left;
    }

    .contact-methods {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .email-info {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        color: #4b5563;
        font-size: 1.1rem;
    }

    .mail-icon {
        color: #6b7280;
        margin-top: 1px;
    }

    .social-links {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .social-links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #4b5563;
        transition: color 0.2s ease, transform 0.2s ease;
    }

    .social-links a:hover {
        color: #111827;
        transform: translateY(-2px);
    }

    .social-icon {
        width: 1.75rem;
        height: 1.75rem;
        display: block;
        filter: grayscale(100%);
        opacity: 0.8;
        transition: filter 0.2s ease, opacity 0.2s ease;
    }

    .social-links a:hover .social-icon {
        filter: grayscale(0%);
        opacity: 1;
    }

    @media (max-width: 860px) {
        .hero {
            grid-template-columns: 1fr;
            padding-top: 2rem;
        }

        .hero-image-wrap {
            order: 1;
        }

        .hero-content {
            order: 2;
            text-align: center;
        }

        .hero-content p {
            margin: 0 auto;
        }

        .contact-area p {
            text-align: center;
        }

        .contact-methods {
            justify-content: center;
            flex-direction: column;
            gap: 1.5rem;
        }

        .email-info {
            justify-content: center;
        }
    }
</style>