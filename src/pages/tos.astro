</Layout>

<style>
    :global(body) {
        font-family:
            system-ui,
            -apple-system,
            Segoe UI,
            Roboto,
            Helvetica,
            Arial,
            sans-serif;
        background: #f8f9fb;
        color: #111827;
    }

    .legal {
        min-height: 100vh;
    }

    .content {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .content h1 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        margin-bottom: 0.5rem;
    }

    .last-updated {
        font-size: 0.95rem;
        color: #6b7280;
        margin-bottom: 2rem;
    }

    .content h2 {
        font-size: 1.75rem;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 0.5rem;
    }

    .content p {
        font-size: 1.125rem;
        line-height: 1.5;
        color: #4b5563;
        margin-bottom: 1.5rem;
        text-align: justify;
    }

    .content h3 {
        font-size: 1.3rem;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        color: #111827;
    }

    .content ul {
        padding-left: 1.5rem;
        margin-bottom: 1.5rem;
        color: #4b5563;
        font-size: 1.125rem;
        line-height: 1.8;
    }

    .content a {
        color: #111827;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s ease;
    }

    .content a:hover {
        border-bottom-color: currentColor;
    }
</style>
