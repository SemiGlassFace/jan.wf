---
<footer class="footer">
    <div class="container">
        <p>&copy; 2026 Jan Piotrowski. All rights reserved.</p>
        <p class="links">
            <a href="/privacy">Privacy Policy</a>
            <span class="separator">&middot;</span>
            <a href="/tos">Terms of Service</a>
        </p>
        <p class="attribution">Icons & logos belong to their respective owners.</p>
    </div>
</footer>

<style>
    .footer {
        padding: 2rem;
        border-top: 1px solid #e5e7eb;
        background: #f8f9fb;
        margin-top: auto;
    }

    .footer .container {
        max-width: 1100px;
        margin: 0 auto;
        text-align: center;
    }

    .footer p {
        color: #6b7280;
        font-size: 0.9rem;
        margin: 0;
    }

    .footer .links {
        margin-top: 0.5rem;
        font-size: 0.85rem;
    }

    .footer .links a {
        color: #6b7280;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .footer .links a:hover {
        color: #111827;
    }

    .footer .separator {
        margin: 0 0.5rem;
        color: #9ca3af;
    }

    .footer .attribution {
        margin-top: 0.5rem;
        font-size: 0.8rem;
        opacity: 0.8;
    }
</style>
